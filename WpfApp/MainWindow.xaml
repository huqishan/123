<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        mc:Ignorable="d" MinWidth="1450" MinHeight="600">
    <ui:NavigationView x:Name="Navigation" IsPaneOpen="True" PaneTitle="WpfApp" IsBackButtonVisible="Collapsed" IsSettingsVisible="True" SelectionChanged="NavigationViewControl_SelectionChanged" Foreground="White">
        <ui:NavigationView.AutoSuggestBox>
            <!--搜索框-->
            <ui:AutoSuggestBox x:Name="controlsSearchBox" MinWidth="200" VerticalAlignment="Center" x:FieldModifier="public" PlaceholderText="Search">
                <ui:AutoSuggestBox.QueryIcon>
                    <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Search}" FontSize="12" RenderTransformOrigin="0.5,0.5">
                        <ui:FontIcon.RenderTransform>
                            <ScaleTransform ScaleX="-1"/>
                        </ui:FontIcon.RenderTransform>
                    </ui:FontIcon>
                </ui:AutoSuggestBox.QueryIcon>
            </ui:AutoSuggestBox>
        </ui:NavigationView.AutoSuggestBox>

        <TabControl x:Name="tabControl" HorizontalAlignment="Stretch">
        </TabControl>
    </ui:NavigationView>
</Window>
