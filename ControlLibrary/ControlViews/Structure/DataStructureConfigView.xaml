<UserControl x:Class="ControlLibrary.ControlViews.Structure.DataStructureConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             d:DesignHeight="760"
             d:DesignWidth="1600">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
<Style x:Key="ConfigListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="BorderBrush" Value="{DynamicResource TabItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource TabCardBackgroundBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="数据结构配置" />
                    <TextBlock Margin="0,6,0,0" Style="{StaticResource AppMutedTextBlockStyle}" Text="支持多配置、JSON/XML、MESCode、ClientCode、数据类型、默认值与 XML 命名空间。" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource AppMutedTextBlockStyle}" Text="{Binding ConfigDirectoryDisplay}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="新增配置" Click="AddProfile_Click" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="复制配置" Click="DuplicateProfile_Click" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="删除配置" Click="DeleteProfile_Click" Style="{StaticResource ActionButtonStyle}" />
                    <Button Content="保存全部" Click="SaveProfiles_Click" Style="{StaticResource PrimaryActionButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitleStyle}" Text="配置列表" />
                    <ListBox Margin="0,14,0,0"
                             ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ConfigListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource AppContentTextBrush}" Text="{Binding Name}" />
                                    <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource AppMutedTextBrush}" Text="{Binding Summary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="配置名称" />
                            <TextBox Text="{Binding SelectedProfile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="格式" />
                            <ComboBox ItemsSource="{Binding Formats}"
                                      SelectedValue="{Binding SelectedProfile.Format, Mode=TwoWay}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      ItemContainerStyle="{StaticResource InputComboBoxItemStyle}"
                                      Style="{StaticResource InputComboBoxStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="根节点/根属性" />
                            <TextBox Text="{Binding SelectedProfile.RootName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="XML 命名空间" />
                            <TextBox Text="{Binding SelectedProfile.XmlNamespace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBoxStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <TextBlock DockPanel.Dock="Left" Style="{StaticResource SectionTitleStyle}" Text="字段配置" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="新增字段" Click="AddField_Click" Style="{StaticResource ActionButtonStyle}" />
                                <Button Content="复制字段" Click="DuplicateField_Click" Style="{StaticResource ActionButtonStyle}" />
                                <Button Content="删除字段" Click="DeleteField_Click" Style="{StaticResource ActionButtonStyle}" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding SelectedProfile.Fields}"
                                  SelectedItem="{Binding SelectedProfile.SelectedField, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{DynamicResource TabCardBackgroundBrush}"
                                  Foreground="{DynamicResource AppContentTextBrush}"
                                  RowBackground="{DynamicResource TabCardBackgroundBrush}"
                                  AlternatingRowBackground="{DynamicResource TabItemBackgroundBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="字段名" Width="1.2*" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn Header="MESCode" Width="1.3*" Binding="{Binding MesCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn Header="ClientCode" Width="1.3*" Binding="{Binding ClientCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridTextColumn Header="数据类型" Width="1*" Binding="{Binding DataType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <DataGridComboBoxColumn Header="JSON 类型" Width="1.2*"
                                                        ItemsSource="{Binding DataContext.JsonValueKinds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        SelectedValueBinding="{Binding JsonValueKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectedValuePath="Value"
                                                        DisplayMemberPath="DisplayName" />
                                <DataGridTextColumn Header="默认值" Width="1.8*" Binding="{Binding DefaultValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource SectionTitleStyle}" Text="结构预览" />
                        <Button DockPanel.Dock="Right" Content="刷新预览" Click="RefreshPreview_Click" Style="{StaticResource ActionButtonStyle}" />
                    </DockPanel>
                    <TextBox Grid.Row="2"
                             Text="{Binding PreviewText, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"
                             TextWrapping="NoWrap"
                             Style="{StaticResource InputTextBoxStyle}" />
                    <TextBlock Grid.Row="4"
                               Text="{Binding PreviewStatusText, Mode=OneWay}"
                               Foreground="{Binding PreviewStatusBrush, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

