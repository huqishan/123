<UserControl x:Class="ControlLibrary.Controls.SearchBox.Control.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ControlLibrary.Controls.SearchBox.Control"
             mc:Ignorable="d"
             d:DesignHeight="46"
             d:DesignWidth="276">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="SearchBoxBorderStyle" TargetType="{x:Type Border}">
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="Height" Value="46" />
                <Setter Property="Background" Value="{DynamicResource NavSearchBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource NavSearchBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="16" />
            </Style>

            <Style x:Key="SearchIconHostStyle" TargetType="{x:Type ContentControl}">
                <Setter Property="Width" Value="14" />
                <Setter Property="Height" Value="14" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SearchTextBoxStyle" TargetType="{x:Type TextBox}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{DynamicResource NavSearchTextBrush}" />
                <Setter Property="CaretBrush" Value="{DynamicResource NavSearchTextBrush}" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="SearchPlaceholderTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource NavSearchPlaceholderBrush}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="IsHitTestVisible" Value="False" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border x:Name="SearchBorder"
            Style="{StaticResource SearchBoxBorderStyle}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ContentControl x:Name="SearchIconHost"
                            Style="{StaticResource SearchIconHostStyle}" />

            <Grid Grid.Column="1" Margin="12,0,0,0">
                <TextBox x:Name="SearchTextBox"
                         Style="{StaticResource SearchTextBoxStyle}"
                         TextChanged="SearchTextBox_TextChanged" />
                <TextBlock x:Name="SearchPlaceholderText"
                           Style="{StaticResource SearchPlaceholderTextBlockStyle}"
                           Text="{Binding PlaceholderText, RelativeSource={RelativeSource AncestorType={x:Type local:SearchBox}}}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
